;;; core-evil.el --- Evil and friends -*- lexical-binding: t; -*-

;; --- Undo backend first, so evil can hook into it ---
(use-package undo-fu
  :config
  ;; Raise undo limits; elisp measures these in bytes.
  (setq undo-limit (* 64 1024 1024)
        undo-strong-limit (* 96 1024 1024)))

;; Persistent undo across restarts — vim's 'undofile'.
(use-package undo-fu-session
  :config
  ;; Don't persist undo for throwaway/ephemeral files.
  (setq undo-fu-session-incompatible-files
        '("/COMMIT_EDITMSG\\'" "/git-rebase-todo\\'"))
  (undo-fu-session-global-mode 1))
;; no-littering already routes the session files into var/.

;; Make ESC quit prompts, like every vim user expects.
(global-set-key [escape] 'keyboard-escape-quit)

;; --- Evil core ---
(use-package evil
  :init
  ;; These MUST be set before evil loads:
  (setq evil-want-keybinding nil     ; required by evil-collection; it takes over
        evil-want-integration t
        evil-want-C-u-scroll t       ; C-u scrolls (default: universal-argument)
        evil-want-C-d-scroll t
        evil-want-C-u-delete t       ; C-u in insert deletes to line start, like vim
        evil-want-Y-yank-to-eol t    ; Y = y$ (you probably have this in nvim)
        evil-undo-system 'undo-fu
        evil-split-window-below t    ; new splits open below/right, like most setups
        evil-vsplit-window-right t)
  :config
  (evil-mode 1)

  ;; Center after half-page scrolls: your "auto zz".
  (advice-add 'evil-scroll-up   :after (lambda (&rest _) (recenter)))
  (advice-add 'evil-scroll-down :after (lambda (&rest _) (recenter)))

  ;; Stay in visual mode after indenting, so > and < are repeatable.
  (evil-define-key 'visual 'global
    (kbd ">") (lambda () (interactive)
                (call-interactively #'evil-shift-right)
                (evil-normal-state)
                (evil-visual-restore))
    (kbd "<") (lambda () (interactive)
                (call-interactively #'evil-shift-left)
                (evil-normal-state)
                (evil-visual-restore))))

;; --- Evil everywhere else: magit, dired, help, compilation, 100+ modes ---
(use-package evil-collection
  :after evil
  :config
  (evil-collection-init))

;; --- gcc / gc<motion> commenting ---
(use-package evil-commentary
  :after evil
  :config (evil-commentary-mode 1))

;; --- % on tags, blocks, if/end pairs (good for tsx, C# regions) ---
(use-package evil-matchit
  :after evil
  :config (global-evil-matchit-mode 1))

;; --- M-j / M-k to drag lines and visual blocks ---
(use-package drag-stuff
  :after evil
  :config
  (evil-define-key '(normal visual) 'global
    (kbd "M-j") #'drag-stuff-down
    (kbd "M-k") #'drag-stuff-up))

(provide 'core-evil)
;;; core-evil.el ends here
