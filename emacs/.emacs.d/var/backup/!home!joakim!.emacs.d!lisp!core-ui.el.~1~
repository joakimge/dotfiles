;;; core-ui.el --- Theme, fonts, modeline -*- lexical-binding: t; -*-

;; --- Font ---
(set-face-attribute 'default nil
                    :family "JetBrainsMono Nerd Font"
                    :height 120)          ; 110 = 11pt; adjust to taste
;; Fallback-check: if the family name doesn't match, run (font-family-list)
;; and grep for "JetBrains" — exact naming varies by packaging.

;; --- Theme (Choice B: modus-vivendi-tritanopia) ---
(use-package modus-themes
  :init
  ;; Options must be set BEFORE loading the theme.
  (setq modus-themes-italic-constructs t   ; italics for comments/doc-strings
        modus-themes-bold-constructs t)
  :config
  (load-theme 'modus-vivendi-tritanopia :no-confirm))

;; --- Modeline (Choice C: stock, lightly informative) ---
(column-number-mode 1)                    ; show column next to line
(setq mode-line-percent-position nil)     ; drop the "Top/23%" noise
;; Trim minor-mode clutter: show nothing in the minor-mode area.
;; (Most useful info — evil state, LSP, VC branch — appears elsewhere
;; or we surface it later. Revisit if you miss something.)
(setq mode-line-modes
      (seq-remove (lambda (x) (and (consp x) (eq (car x) 'minor-mode-alist)))
                  mode-line-modes))

;; --- Line numbers: relative, prog/text only ---
(setq display-line-numbers-type 'relative
      display-line-numbers-width 3)       ; stable gutter width
(add-hook 'prog-mode-hook #'display-line-numbers-mode)
(add-hook 'text-mode-hook #'display-line-numbers-mode)

;; --- Current-line highlight, non-intrusive ---
;; Modus themes give hl-line a subtle background by design; scoping it to
;; prog/text (not global) keeps it out of terminals, magit, etc.
(add-hook 'prog-mode-hook #'hl-line-mode)
(add-hook 'text-mode-hook #'hl-line-mode)

;; --- Helpful: superior C-h buffers ---
(use-package helpful
  :bind (([remap describe-function] . helpful-callable)
         ([remap describe-variable] . helpful-variable)
         ([remap describe-key]      . helpful-key)
         ([remap describe-command]  . helpful-command)
         ("C-h F" . helpful-function)))   ; functions only, excludes macros

(provide 'core-ui)
;;; core-ui.el ends here
